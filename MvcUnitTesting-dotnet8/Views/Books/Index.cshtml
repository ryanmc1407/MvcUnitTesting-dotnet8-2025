@model IEnumerable<MvcUnitTesting_dotnet8.Models.Book>

<h1>Production Book List</h1>
<table class="table">
    <thead>
        <tr>
            <th>Name</th>
            <th>Genre</th>
            <th>Price</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Name</td>
                <td>@item.Genre</td>
                <td>@item.Price</td>
            </tr>
        }
    </tbody>
</table>